{
  "name": "Tableau MCP with Copilot",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:24-trixie",
  "secrets": {
    "TMCP_SERVER": {
      "description": "Tableau server URL (e.g. https://10ax.online.tableau.com or https://tableau.example.com).",
      "documentationUrl": "https://tableau.github.io/tableau-mcp/docs/configuration/mcp-config/env-vars"
    },
    "TMCP_SITE_NAME": {
      "description": "Tableau site name. For Tableau Server, set this to an empty string to specify the default site.",
      "documentationUrl": "https://tableau.github.io/tableau-mcp/docs/configuration/mcp-config/env-vars"
    },
    "TMCP_PAT_NAME": {
      "description": "Personal Access Token name.",
      "documentationUrl": "https://tableau.github.io/tableau-mcp/docs/configuration/mcp-config/authentication/pat"
    },
    "TMCP_PAT_VALUE": {
      "description": "Personal Access Token value.",
      "documentationUrl": "https://tableau.github.io/tableau-mcp/docs/configuration/mcp-config/authentication/pat"
    }
  },
  "customizations": {
    "vscode": {
      "mcp": {
        "servers": {
          "tableau": {
            "command": "npx",
            "args": ["-y", "@tableau/mcp-server@latest"],
            "env": {
              "TRANSPORT": "stdio",
              "SERVER": "${localEnv:TMCP_SERVER}",
              "SITE_NAME": "${localEnv:TMCP_SITE_NAME:-}",
              "PAT_NAME": "${localEnv:TMCP_PAT_NAME}",
              "PAT_VALUE": "${localEnv:TMCP_PAT_VALUE}",
              "DATASOURCE_CREDENTIALS": "",
              "DEFAULT_LOG_LEVEL": "info",
              "INCLUDE_TOOLS": "",
              "EXCLUDE_TOOLS": "",
              "MAX_RESULT_LIMIT": "",
              "DISABLE_QUERY_DATASOURCE_FILTER_VALIDATION": ""
            }
          }
        }
      },
      "settings": {
        "ts.preferences.includePackageJsonAutoImports": "on",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "extensions.ignoreRecommendations": true,
        "mcp.mcpServers.autoStart": true,
        "mcp.mcpServers.enabledByDefault": true
      }
    }
  },
  "postCreateCommand": "sh .devcontainer/post-create.sh",
  "onCreateCommand": "echo 'Container created'",
  "remoteUser": "node"
}
